rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Helper Functions ──────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isShopOwner(shopId) {
      return isAuthenticated() && (
        request.auth.uid == shopId ||
        (
          exists(/databases/$(database)/documents/shops/$(shopId)) &&
          (
            get(/databases/$(database)/documents/shops/$(shopId)).data.get('ownerId', '') == request.auth.uid ||
            get(/databases/$(database)/documents/shops/$(shopId)).data.get('ownerUid', '') == request.auth.uid
          )
        )
      );
    }

    // Dual check: prevents email case mismatch issues while remaining secure
    function isStaffOf(shopId) {
      return isAuthenticated() && (
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          ) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessShopId == shopId
        )
        ||
        (
          exists(/databases/$(database)/documents/shops/$(shopId)) &&
          request.auth.token.email != null &&
          request.auth.token.email in get(/databases/$(database)/documents/shops/$(shopId)).data.get('staffEmails', [])
        )
      );
    }

    function isShopAdmin(shopId) {
      return isShopOwner(shopId) || isSuperAdmin() || isStaffOf(shopId);
    }

    function isUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // Secure Role Assignment: Blocks Superadmin escalation but allows Staff IF verified against the shop's email list
    function isValidRoleAssignment() {
      let role = request.resource.data.get('role', 'user');
      let shopId = request.resource.data.get('accessShopId', 'none');
      
      return role != 'superadmin' && (
        role != 'staff' || 
        (
          exists(/databases/$(database)/documents/shops/$(shopId)) &&
          request.auth.token.email != null &&
          request.auth.token.email in get(/databases/$(database)/documents/shops/$(shopId)).data.get('staffEmails', [])
        )
      );
    }

    // ── Config & Invites ──────────────────────────────────────────
    match /config/global {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /retailer_requests/{docId} {
      allow create: if isAuthenticated() && request.auth.uid == docId;
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == docId);
      allow update, delete: if isSuperAdmin();
    }
    
    match /retailer_invites/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
      
      // Apply secure role validation on creation
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidRoleAssignment();
      
      // Apply secure role validation on update (fixes staff login permission issue)
      allow update: if isAuthenticated() && request.auth.uid == userId
                    && (
                      (isUnchanged('role') && isUnchanged('accessShopId')) ||
                      isValidRoleAssignment()
                    );
      allow delete: if false;
    }

    // ── Shops & Sub-collections ───────────────────────────────────
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == shopId;
      allow update: if isShopAdmin(shopId);
      allow delete: if isSuperAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isShopAdmin(shopId);
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isShopOwner(shopId) || isSuperAdmin();
      }

      match /orders/{orderId} {
        allow create: if false; 
        allow read: if isShopAdmin(shopId) || (isAuthenticated() && resource.data.customerEmail == request.auth.token.email);
        allow update, delete: if isShopAdmin(shopId);
      }

      match /incomplete_orders/{orderId} {
        allow read, write: if isShopAdmin(shopId);
      }

      match /counters/{counterId} {
        allow read, write: if isShopAdmin(shopId);
      }

      match /staff/{staffId} {
        allow read: if isShopAdmin(shopId);
        allow write: if isShopOwner(shopId) || isSuperAdmin();
      }

      match /customers/{customerId} {
        allow read: if isShopAdmin(shopId);
        allow write: if isShopAdmin(shopId);
      }

      // Reviews: public read, created via server API (no client create)
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if false; // Server-only via Admin SDK
        allow update, delete: if isShopAdmin(shopId);
      }

      // Broadcasts: admin-only (log of sent broadcasts)
      match /broadcasts/{broadcastId} {
        allow read: if isShopAdmin(shopId);
        allow create: if false; // Server-only via Admin SDK
        allow update, delete: if false;
      }

      // Private Configs: only accessible by the shop owner (retailer)
      match /private_configs/{configId} {
        allow read, write: if isShopOwner(shopId);
      }
    }
    
    // ── System Logs & Broadcasts ──────────────────────────────────
    match /impersonation_logs/{logId} {
      allow create: if isSuperAdmin();
      allow read: if isSuperAdmin();
    }

    match /broadcasts/{broadcastId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Server-Managed Collections (Admin SDK only) ──────────
    // PEN-H6: Explicit deny rules for collections managed exclusively via Admin SDK
    // These were covered by default deny but explicit rules are enterprise best practice

    // Platform reviews — created via /api/platform-review
    match /platform_reviews/{reviewId} {
      allow read: if true;  // Public listing
      allow create, update, delete: if false;  // Server-only via Admin SDK
    }

    // Retailer signup requests — managed by superadmin
    match /retailer_requests/{requestId} {
      allow create: if isAuthenticated();  // Users can submit applications
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow update, delete: if false;  // Server-only via Admin SDK
    }

    // OTP codes — managed by /api/auth/send-otp and verify-otp
    match /otp_codes/{otpId} {
      allow read, write: if false;  // Server-only
    }

    // OTP rate limits — managed by /api/auth/send-otp
    match /otp_rate_limits/{limitId} {
      allow read, write: if false;  // Server-only
    }

    // Global config — piprapay settings, etc
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    // Shared Enterprise Fraud Profiles (Retailer Community Database)
    match /fraud_profiles/{phone} {
      allow read, write: if isAuthenticated();
    }
    
    // ── Default Deny ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
