rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════════════
    // 🔐 WEBMAA PRODUCTION FIRESTORE RULES
    // Last Updated: 2026-04-20
    // Principle: DENY BY DEFAULT, allow only what's necessary
    // ═══════════════════════════════════════════════════════════════

    // ── Helper Functions ──────────────────────────────────────────

    // ইউজার লগইন করা কিনা
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // সুপার অ্যাডমিন কিনা (Firestore-এ role চেক করা)
    function isSuperAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // এই শপের মালিক কিনা (shopId = user UID)
    function isShopOwner(shopId) {
      return isAuthenticated() && request.auth.uid == shopId;
    }

    // এই শপের Staff কিনা (staffEmails array-তে email আছে কিনা)
    function isStaffOf(shopId) {
      return isAuthenticated() && 
             request.auth.token.email in get(/databases/$(database)/documents/shops/$(shopId)).data.staffEmails;
    }

    // শপ মালিক অথবা Staff
    function isShopAdmin(shopId) {
      return isShopOwner(shopId) || isStaffOf(shopId) || isSuperAdmin();
    }


    // ═══════════════════════════════════════════════════════════════
    // 1. GLOBAL CONFIG (API Keys etc)
    //    ⚠️ আগে allow read: if true ছিল — এখন auth লাগবে
    //    Gemini API key এখানে store হয়, তাই public করা যাবে না
    // ═══════════════════════════════════════════════════════════════
    match /config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // 2. RETAILER REQUESTS & INVITES
    //    Request: সবাই নিজের জন্য তৈরি করতে পারবে
    //    Invite: শুধু সুপার অ্যাডমিন
    // ═══════════════════════════════════════════════════════════════
    match /retailer_requests/{docId} {
      allow create: if isAuthenticated() && request.auth.uid == docId;
      allow read: if isSuperAdmin() || 
                    (isAuthenticated() && request.auth.uid == docId);
      allow update, delete: if isSuperAdmin();
    }
    
    match /retailer_invites/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // 3. USERS COLLECTION
    //    প্রত্যেকে শুধু নিজের ডাটা পড়তে/লিখতে পারবে
    //    সুপার অ্যাডমিন সবার ডাটা পড়তে পারবে
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isSuperAdmin() || 
                    (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false; // ইউজার ডিলিট করা যাবে না
    }

    // ═══════════════════════════════════════════════════════════════
    // 4. SHOPS & ALL SUB-COLLECTIONS
    //    Read: পাবলিক (স্টোরফ্রন্ট দেখার জন্য)
    //    Write: শুধু Shop Owner (uid == shopId)
    // ═══════════════════════════════════════════════════════════════
    match /shops/{shopId} {
      // যেকেউ শপ দেখতে পারবে (storefront)
      allow read: if true;
      
      // শুধু শপের মালিক বা সুপার অ্যাডমিন লিখতে পারবে
      // ⚠️ আগে allow write: if isAuthenticated() ছিল — যেকেউ অন্যের শপ বদলাতে পারতো!
      allow create: if isAuthenticated() && request.auth.uid == shopId;
      allow update: if isShopOwner(shopId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // ── Products ──────────────────────────────────────────────
      // পড়া: পাবলিক | লেখা: শপ মালিক/স্টাফ
      match /products/{productId} {
        allow read: if true;
        allow write: if isShopAdmin(shopId);
      }

      // ── Categories ────────────────────────────────────────────
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isShopAdmin(shopId);
      }

      // ── Orders ────────────────────────────────────────────────
      // ⚠️ আগে allow read, create: if true ছিল — বট দিয়ে ফেক অর্ডার দেওয়া যেতো!
      // এখন: create এ auth optional (guest checkout সাপোর্ট), 
      // কিন্তু বাধ্যতামূলক ফিল্ড ভ্যালিডেশন আছে
      match /orders/{orderId} {
        // 🚨 ZERO TRUST: Frontend can no longer create orders.
        // Orders MUST be created securely via the Next.js API (/api/checkout)
        allow create: if false;
        
        // অর্ডার পড়া: শপ মালিক/স্টাফ, অথবা অর্ডারের মালিক
        allow read: if isShopAdmin(shopId) ||
                      (isAuthenticated() && resource.data.customerEmail == request.auth.token.email);
        
        // অর্ডার আপডেট/ডিলিট: শুধু শপ মালিক/স্টাফ
        allow update, delete: if isShopAdmin(shopId);
      }

      // ── Order Counters (Serial Number) ────────────────────────
      match /counters/{counterId} {
        allow read, write: if true;  // Transaction-based, short-lived
      }

      // ── Staff ──────────────────────────────────────────────────
      match /staff/{staffId} {
        allow read: if isShopAdmin(shopId);
        allow write: if isShopOwner(shopId) || isSuperAdmin();
      }

      // ── Customers ──────────────────────────────────────────────
      match /customers/{customerId} {
        allow read: if isShopAdmin(shopId);
        allow write: if isShopAdmin(shopId);
      }
    }
    
    // ═══════════════════════════════════════════════════════════════
    // 🚫 FALLBACK: বাকি সব কিছু BLOCK
    // এটা সবচেয়ে গুরুত্বপূর্ণ — নতুন collection তৈরি হলে
    // সেটা by default বন্ধ থাকবে
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
