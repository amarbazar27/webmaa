rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if the user is a superadmin
    // (Assuming user document has role == 'superadmin')
    function isSuperAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // 1. Global Config (API Keys etc)
    match /config/{document=**} {
      // Anyone can read config (so frontend gets API keys for AI)
      allow read: if true;
      // Only superadmin can change config
      allow write: if isSuperAdmin();
    }

    // 2. Retailer Requests and Invites
    match /retailer_requests/{docId} {
      allow create: if isAuthenticated();
      allow read: if isSuperAdmin() || (isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid));
      allow update, delete: if isSuperAdmin();
    }
    match /retailer_invites/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // 3. Users Collection
    match /users/{userId} {
      // Users can read/write their own data; Superadmins can read all
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 4. Shops and Nested Subcollections
    match /shops/{shopId} {
      // Anyone can visit a shop and read its details
      allow read: if true;
      
      // Creating/Updating/Deleting shops requires authentication
      // (Advanced: you can restrict write to shop owner/staff via a function, 
      // but for simplicity, we require at least an auth token for creation)
      allow write: if isAuthenticated();

      match /products/{productId} {
        // Products are public
        allow read: if true;
        // Only authenticated users (retailers/staff) can modify
        allow write: if isAuthenticated();
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }

      match /orders/{orderId} {
        // Anyone can place an order (create) or read an order
        // (In future: restrict reading orders only to the shop staff or the user who placed it)
        allow read, create: if true;
        // Updating order status requires authentication
        allow update, delete: if isAuthenticated();
      }

      match /staff/{staffId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }
    
    // Fallback block EVERYTHING else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
