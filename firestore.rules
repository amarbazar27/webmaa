rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════════════
    // 🔐 WEBMAA PRODUCTION FIRESTORE RULES
    // Principle: DENY BY DEFAULT, allow only what's necessary
    // ═══════════════════════════════════════════════════════════════

    // ── Helper Functions ──────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isShopOwner(shopId) {
      return isAuthenticated() && request.auth.uid == shopId;
    }

    function isStaffOf(shopId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/shops/$(shopId)) &&
             request.auth.token.email in get(/databases/$(database)/documents/shops/$(shopId)).data.staffEmails;
    }

    function isShopAdmin(shopId) {
      return isShopOwner(shopId) || isSuperAdmin() || isStaffOf(shopId);
    }


    // ═══════════════════════════════════════════════════════════════
    // 1. GLOBAL CONFIG (API Keys etc)
    // ═══════════════════════════════════════════════════════════════
    match /config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // 2. RETAILER REQUESTS & INVITES
    // ═══════════════════════════════════════════════════════════════
    match /retailer_requests/{docId} {
      allow create: if isAuthenticated() && request.auth.uid == docId;
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == docId);
      allow update, delete: if isSuperAdmin();
    }
    
    match /retailer_invites/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // 3. USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // 4. SHOPS & ALL SUB-COLLECTIONS
    // ═══════════════════════════════════════════════════════════════
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == shopId;
      allow update: if isShopOwner(shopId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // ── Products ──────────────────────────────────────────────
      match /products/{productId} {
        allow read: if true;
        allow write: if isShopAdmin(shopId);
      }

      // ── Categories ────────────────────────────────────────────
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isShopAdmin(shopId);
      }

      // ── Orders ────────────────────────────────────────────────
      match /orders/{orderId} {
        allow create: if false; // Only via API
        allow read: if isShopAdmin(shopId) || (isAuthenticated() && resource.data.customerEmail == request.auth.token.email);
        allow update, delete: if isShopAdmin(shopId);
      }

      // ── Order Counters ────────────────────────────────────────
      match /counters/{counterId} {
        allow read, write: if true;
      }

      // ── Staff ──────────────────────────────────────────────────
      match /staff/{staffId} {
        allow read: if isShopAdmin(shopId);
        allow write: if isShopOwner(shopId) || isSuperAdmin();
      }

      // ── Customers ──────────────────────────────────────────────
      match /customers/{customerId} {
        allow read: if isShopAdmin(shopId);
        allow write: if isShopAdmin(shopId);
      }
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
