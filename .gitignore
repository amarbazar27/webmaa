*.pem
Thumbs.db
.vscode/settings.json

# ── Debug Logs ──────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Test Coverage ───────────────────────────────
/coverage

# ── Patch/Fix Scripts (one-time use) ────────────
fix_*.js
build_*.js
patch_*.js
update_*.js
add_*.js
set_env.js
scratch.jsx
old_*.jsx
old_*.js

