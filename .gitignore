!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js Build Output ────────────────────────
/.next/
/out/
/build

# ── Environment Variables (NEVER commit these!) ─
.env
.env.local
.env.*.local
.env.production.local
.env.vercel.local

# ── Vercel ──────────────────────────────────────
.vercel

# ── TypeScript ──────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS & Editor ─────────────────────────────────
