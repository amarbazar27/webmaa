# ════════════════════════════════════════════════════════════
# WEBMAA — Environment Variables Template
# ════════════════════════════════════════════════════════════
# 1. এই ফাইলটি কপি করুন: cp .env.example .env.local
# 2. সব values পূরণ করুন
# 3. কখনো .env.local GitHub-এ push করবেন না!
# ════════════════════════════════════════════════════════════

# ── Firebase Configuration ──────────────────────────────────
# Firebase Console → Project Settings → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ── Firebase Web Push (VAPID Key) ───────────────────────────
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# "Generate key pair" করুন, তারপর public key copy করুন
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BNAbc...your-vapid-key-here

# ── Super Admin Email ───────────────────────────────────────
# এই Gmail দিয়ে login করলে superadmin access পাবে
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=your-email@gmail.com

# ── Impersonation Security ──────────────────────────────────
# Random string (32+ characters) — https://generate-secret.vercel.app/32
SUPERADMIN_IMPERSONATE_SECRET=your-super-secret-32-char-random-string

# ── Firebase Admin SDK (Server-side) ───────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# JSON ফাইল ডাউনলোড হবে, সেখান থেকে এই দুটো value নিন
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# ⚠️ Private key-এ newlines আছে — Vercel-এ হুবহু paste করুন (quotes সহ)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# ── Google Gemini AI ────────────────────────────────────────
# https://aistudio.google.com/app/apikey
# Superadmin dashboard থেকেও সেট করা যায়
GEMINI_API_KEY=AIzaSy...

# ── Optional: Analytics ─────────────────────────────────────
# Google Analytics 4 Measurement ID (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
