# =========================================================================
# BDRETAILERS CONFIGURATION FILE - ENV TEMPLATE
# =========================================================================

# ── FIREBASE CREDENTIALS ────────────────────────────────────────────────
# Firebase Admin Configuration (Required for server-side APIs)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Public Configuration
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-storage-bucket.appspot.com

# ── ENTERPRISE FRAUD DETECTION API (FRAUD BD) ───────────────────────────
FRAUD_BD_API_KEY=your_fraud_bd_api_key

# -------------------------------------------------------------------------
# FRAUD BD API KEY সেটআপ গাইড (ধাপে ধাপে বাংলায়)
# -------------------------------------------------------------------------
#
# ১. একাউন্ট রেজিস্ট্রেশন:
#    - প্রথমে ব্রাউজারে 'https://fraudbd.com' ওয়েবসাইটে যান।
#    - একটি নতুন মার্চেন্ট একাউন্ট তৈরি (Sign Up) করুন এবং আপনার প্রোফাইল সম্পূর্ণ করুন।
#
# ২. এপিআই কি (API Key) সংগ্রহ:
#    - একাউন্টে লগইন করার পর বামপাশের মেনু থেকে 'API settings' অথবা 'Developer settings' এ ক্লিক করুন।
#    - সেখানে আপনার মার্চেন্টের জন্য একটি ইউনিক API Key দেখতে পাবেন।
#    - এপিআই কি-টি কপি করে নিন।
#
# ৩. লোকাল ডেভেলপমেন্টে অ্যাড করা:
#    - এই প্রজেক্টের রুট ডিরেক্টরিতে '.env.local' নামের একটি ফাইল তৈরি করুন (যদি না থাকে)।
#    - ফাইলে নিচের লাইনটি যুক্ত করুন এবং 'your_fraud_bd_api_key' এর জায়গায় কপি করা কি-টি পেস্ট করুন:
#      FRAUD_BD_API_KEY=FBD_xxxxxxxxx_xxxxxxxxxx
#
# ৪. প্রোডাকশনে (Vercel) অ্যাড করা:
#    - আপনার Vercel ড্যাশবোর্ডে গিয়ে প্রজেক্টের 'Settings' > 'Environment Variables' এ যান।
#    - Key এর জায়গায় 'FRAUD_BD_API_KEY' লিখুন।
#    - Value এর জায়গায় আপনার এপিআই কি-টি দিয়ে 'Save' বা 'Add' বাটনে ক্লিক করুন।
#    - প্রজেক্টটি পুনরায় রিবিল্ড/রিডিপ্লয় করুন।
#
# ৫. টেস্টিং:
#    - আপনার একাউন্টে ফ্রিতে টেস্ট করার জন্য ডেমো রেসপন্স ব্যবহার করতে পারেন।
#    - লোকাল সার্ভারে টেস্ট করতে `npm run dev` কমান্ডটি ব্যবহার করুন।
#
# =========================================================================
